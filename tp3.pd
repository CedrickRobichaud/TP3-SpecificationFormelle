const N : nat ^= 2;
const NB_P : nat ^= 3;
const NB_S : nat ^= 4;

class Message ^= tag;

class Etat ^=
	enum
		CREE,
		PUBLIE,
		SUB,
		CONSOMME
	end;

class Type ^=
	enum
		I,
		T
	end;
  
class Publisher ^=
	abstract
		var
			type : Type,
			messages : set of Message,
			etats : map of (Message -> Etat),
			ids : map of (Message -> string);
		invariant
			etats.dom = messages,
			etats.ran <<= set of (Etat){CREE@Etat, PUBLIE@Etat},
			ids.dom = messages,
			forall x1,x2::(ids.dom) :- ids[x1] = ids[x2] ==> x1 = x2;
	interface
		build {t : Type}
			post
				type! = t,
				messages! = set of Message{},
				etats! = map of (Message -> Etat){},
				ids! = map of (Message -> string){};

		function type;
		
		function aPublieMessage(m : Message) : bool ^=
			m in messages & etats[m] = PUBLIE@Etat;

		schema !creerMessages(m : Message, id : string)
			pre
				m ~in messages,
				id ~in ids.ran
			post
				messages! = messages.append(m),
				etats! = etats.append(pair of (Message, Etat){m, CREE@Etat}),
				ids! = ids.append(pair of (Message, string){m, id});

		
		schema !publierMessage(m : Message)
			pre
				m in messages,
				etats[m] = CREE@Etat
			post
				etats! = (etats -- set of (Message) {m}).append(pair of (Message, Etat) {m, PUBLIE@Etat});
		
		schema !effacerMessage(m : Message)
			pre
				m in messages,
				etats[m] = PUBLIE@Etat
			post
				messages! = messages.remove(m),
				etats! = etats -- set of (Message){m},
				ids! = ids -- set of (Message){m},
				type! = type;
		
		schema !fermerPublisher
			post
				messages! = set of Message{},
				etats! = map of (Message -> Etat){},
				ids! = map of (Message -> string){},
				type! = type;
	end;
  
class Subscriber ^=
	abstract
		var
			type : Type,
			messages : set of Message,
			etats : map of (Message -> Etat),
			ids : map of (Message -> string);
		invariant
			etats.dom = messages,
			etats.ran <<= set of (Etat){SUB@Etat, CONSOMME@Etat},
			ids.dom = messages,
			forall x1,x2::(ids.dom) :- ids[x1] = ids[x2] ==> x1 = x2;
	interface
		build {t : Type}
			post
				type! = t,
				messages! = set of Message{},
				etats! = map of (Message -> Etat){},
				ids! = map of (Message -> string){};

		function type;
		
		function aConsommeMessage(m : Message) : bool ^=
			m in messages & etats[m] = CONSOMME@Etat;

		schema !consommerMessage(m : Message)
			pre
				m in messages,
				etats[m] = SUB@Etat
			post
				messages! = messages,
				etats! = (etats -- set of (Message){m}) ++ (map of (Message -> Etat) {m -> CONSOMME@Etat}),
				ids! = ids,
				type! = type;
		
		schema !subMessages(ms : set of Message, idss : map of (Message -> string))
			pre
        (ms ** messages).empty,
		idss.dom = ms,
        forall m::(ms) :- ~(idss[m] in ids.ran),
        idss.dom = ms,
        forall m1,m2::(ms) :- idss[m1] = idss[m2] ==> m1 = m2
			post
        messages! = messages ++ ms,
		etats! =etats ++ map of (Message -> Etat){for m :: ms yield pair of (Message, Etat){m, SUB@Etat}},
        ids! = ids ++ idss;
				
		
		schema !effacerMessages(ms : set of Message)
			pre
				ms <<= messages,
				forall m :: ms :- etats[m] = CONSOMME@Etat
			post
				messages! = messages -- ms,
				ids! = ids -- ms,
				etats! = etats -- ms,
				type! = type;

		schema !fermerSubscriber
			post
				messages! = set of Message{},
		        etats! = map of (Message -> Etat){},
		        ids! = map of (Message -> string){};
	end;

class Broker ^=
	abstract
		var
			messages : seq of pair of (Type, Message),
			etats : map of (Message -> Etat),
			publishers : set of Publisher,
			subscribers : set of Subscriber,
			delaiDeRetention : nat,
			maintenant : nat,
			tempsArrives : map of (Message -> nat);
			
		invariant
			forall m1,m2::messages :- m1 ~= m2 ==> m1.y ~= m2.y,
			(for m::messages.ran yield m.y) = etats.dom,
			etats.ran <<= set of Etat{PUBLIE@Etat, SUB@Etat},
			#etats <= N,
			forall t:Type :- #(those p::publishers :- p.type = t) <= NB_P,
			forall t:Type :- #(those s::subscribers :- s.type = t) <= NB_S,
			etats.dom = tempsArrives.dom,
			delaiDeRetention > 0;
			
	interface
		build {delai, n : nat}
			pre
				delai > 0
			post
				messages! = seq of pair of (Type, Message){},
				etats! = map of (Message -> Etat){},
				publishers! = set of Publisher{},
				subscribers! = set of Subscriber{},
				delaiDeRetention! = delai,
				maintenant! = n,
				tempsArrives! = map of (Message -> nat){};

		schema !tick
			post
				maintenant! = maintenant+1;
		
		schema !ajouterPublisher(pub : Publisher)
			pre
				~(pub in publishers),
				#(those p::publishers :- p.type = pub.type) < NB_P
			post
				publishers! = publishers.append(pub),
				messages! = messages,
				etats! = etats,
				subscribers! = subscribers,
				delaiDeRetention! = delaiDeRetention,
				maintenant! = maintenant,
				tempsArrives! = tempsArrives;
		
		schema !ajouterSubscriber(sub : Subscriber)
			pre
			~(sub in subscribers),
		    // sub ~in subscribers,
			#(those s::subscribers :- s.type = sub.type) < NB_S
			post
			subscribers! =subscribers.append(sub),//; with ou add append copi� de l exemple de la bibliotheque  ?
			messages! = messages,
			etats! = etats,// � verifi� cette ligne 
			publishers! = publishers,
			delaiDeRetention! = delaiDeRetention,
			maintenant! = maintenant,
			tempsArrives! = tempsArrives;
		
		schema !recevoirMessage(m : Message, t : Type)
			pre
				exists p::publishers :- (p.type = t & (p.aPublieMessage(m))),
				~(exists ms::messages :- ms.y = m),
				~(m in etats.dom),
				#etats < N,
				#messages < N
			post
				messages! = messages.append(pair of (Type, Message) {t, m}),
				etats! = etats.append(pair of (Message, Etat) {m, PUBLIE@Etat}),
				tempsArrives! =  (tempsArrives -- set of (Message){m} ) ++ (map of (Message -> nat) {m -> maintenant}),
				publishers! = publishers,
				subscribers! = subscribers,
				delaiDeRetention! = delaiDeRetention,
				maintenant! = maintenant;

		schema !envoyerMessage(m : Message)
			pre
				m in etats.dom,
				etats[m] = PUBLIE@Etat,
				exists s::subscribers :- ((exists p::messages :- p.y = m & s.type = p.x) & (s.aConsommeMessage(m))),
				// M�thode #1 avec 2 forall
				//forall i::messages.dom :- messages[i].y = m 
				//	==> (forall j::messages.dom :- i ~= j & messages[i].x = messages[j].x & etats[messages[j].y] = PUBLIE@Etat ==> i < j),
				// M�thode #2 avec 1 forall et un exist -- plus propre a mon avis 
				forall i::messages.dom :- messages[i].y ~= m & (exists p::messages :- p.y = m & p.x = messages[i].x) & etats[messages[i].y] = PUBLIE@Etat 
					==> (exists t::messages.dom :- messages[i].y = m & t<i)
			post
				messages! = messages,
				etats! = (etats -- set of (Message){m}) ++ (map of (Message -> Etat) {m -> SUB@Etat}),
				publishers! = publishers,
				subscribers! = subscribers,
				delaiDeRetention! = delaiDeRetention,
				maintenant! = maintenant,
				tempsArrives! = tempsArrives;

		schema !supprimerMessagesTempsExpire
			post
		       ?;
end;
