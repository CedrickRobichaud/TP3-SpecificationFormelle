const N : nat ^= 2;
const NB_P : nat ^= 3;
const NB_S : nat ^= 4;

class Message ^= tag;

class Etat ^=
	enum
		CREE,
		PUBLIE,
		SUB,
		CONSOMME
	end;

class Type ^=
	enum
		I,
		T
	end;
  
class Publisher ^=
	abstract
		var
			type : Type,
			messages : set of Message,
			etats : map of (Message -> Etat),
			ids : map of (Message -> string);
		invariant
			etats.dom = messages,
			etats.ran <<= set of (Etat){CREE@Etat, PUBLIE@Etat},
			ids.dom = messages,
			forall x1,x2::(ids.dom) :- ids[x1] = ids[x2] ==> x1 = x2;
	interface
		build {t : Type}
			post
				type! = t,
				messages! = set of Message{},
				etats! = map of (Message -> Etat){},
				ids! = map of (Message -> string){};

		function type;
		
		function aPublieMessage(m : Message) : bool ^=
			m in messages & etats[m] = PUBLIE@Etat;

		schema !creerMessages(m : Message, id : string)
			pre
				m ~in messages,
				id ~in ids.ran
			post
				messages! = messages.append(m),
				etats! = etats.append(pair of (Message, Etat){m, CREE@Etat}),
				ids! = ids.append(pair of (Message, string){m, id});

		
		schema !publierMessage(m : Message)
			pre
				m in messages,
				etats[m] = CREE@Etat
			post
				//TODO: Call effacer message pour ne plus avoir l'erreur
				etats! = etats.append(pair of (Message, Etat) {m, PUBLIE@Etat});
		
		schema !effacerMessage(m : Message)
			pre
				?
			post
				?;
		
		schema !fermerPublisher
			post
				?;
	end;
  
class Subscriber ^=
	abstract
		var
			type : Type,
			messages : set of Message,
			etats : map of (Message -> Etat),
			ids : map of (Message -> string);
		invariant
			etats.dom = messages,
			etats.ran <<= set of (Etat){SUB@Etat, CONSOMME@Etat},
			ids.dom = messages,
			forall x1,x2::(ids.dom) :- ids[x1] = ids[x2] ==> x1 = x2;
	interface
		build {t : Type}
			post
				type! = t,
				messages! = set of Message{},
				etats! = map of (Message -> Etat){},
				ids! = map of (Message -> string){};

		function type;
		
		function aConsommeMessage(m : Message) : bool ^=
			m in messages & etats[m] = CONSOMME@Etat;

		schema !consommerMessage(m : Message)
			pre
				?
			post
				?;
		
		schema !subMessages(ms : set of Message, idss : map of (Message -> string))
			pre
        (ms ** messages).empty,
		idss.dom = ms,
        forall m::(ms) :- ~(idss[m] in ids.ran),
        idss.dom = ms,
        forall m1,m2::(ms) :- idss[m1] = idss[m2] ==> m1 = m2
			post
        messages! = messages ++ ms,
		etats! =etats ++ map of (Message -> Etat){for m :: ms yield pair of (Message, Etat){m, SUB@Etat}},
        ids! = ids ++ idss;
				
		
		schema !effacerMessages(ms : set of Message)
			pre
				?
			post
				?;
		
		schema !fermerSubscriber
			post
				messages! = set of Message{},
		        etats! = map of (Message -> Etat){},
		        ids! = map of (Message -> string){};
	end;

class Broker ^=
	abstract
		var
			messages : seq of pair of (Type, Message),
			etats : map of (Message -> Etat),
			publishers : set of Publisher,
			subscribers : set of Subscriber,
			delaiDeRetention : nat,
			maintenant : nat,
			tempsArrives : map of (Message -> nat);
			
		invariant
			forall m1,m2::messages :- m1 ~= m2 ==> m1.y ~= m2.y,
			(for m::messages.ran yield m.y) = etats.dom,
			etats.ran <<= set of Etat{PUBLIE@Etat, SUB@Etat},
			#etats <= N,
			forall t:Type :- #(those p::publishers :- p.type = t) <= NB_P,
			forall t:Type :- #(those s::subscribers :- s.type = t) <= NB_S,
			etats.dom = tempsArrives.dom,
			delaiDeRetention > 0;
			
	interface
		build {delai, n : nat}
			pre
				delai > 0
			post
				messages! = seq of pair of (Type, Message){},
				etats! = map of (Message -> Etat){},
				publishers! = set of Publisher{},
				subscribers! = set of Subscriber{},
				delaiDeRetention! = delai,
				maintenant! = n,
				tempsArrives! = map of (Message -> nat){};

		schema !tick
			post
				maintenant! = maintenant+1;
		
		schema !ajouterPublisher(pub : Publisher)
			pre
				?
			post
				?;
		
		schema !ajouterSubscriber(sub : Subscriber)
			pre
			~(sub in subscribers),
		    // sub ~in subscribers,
			#(those s::subscribers :- s.type = sub.type) < NB_S
			post
			subscribers! =subscribers.append(sub),//; with ou add append copié de l exemple de la bibliotheque  ?
			messages! = messages,
			etats! = etats,// ŕ verifié cette ligne 
			publishers! = publishers,
			delaiDeRetention! = delaiDeRetention,
			maintenant! = maintenant,
			tempsArrives! = tempsArrives;
		
		schema !recevoirMessage(m : Message, t : Type)
			pre
				?
			post
				?;

		schema !envoyerMessage(m : Message)
			pre
				?
			post
				?;

		schema !supprimerMessagesTempsExpire
			post
		       ?;
end;